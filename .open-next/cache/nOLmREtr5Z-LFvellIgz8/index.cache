,null,[\"$\",\"div\",null,{\"className\":\"Profile_description__OMT9q\",\"children\":[[\"$\",\"p\",\"p-0\",{\"children\":\"Developed an app enabling users to scan item barcodes to preview vinyl/cassette content, reducing employee workload by 1-3 hours daily\"}],\"\\n\",[\"$\",\"p\",\"p-1\",{\"children\":[\"Publications: \",[\"$\",\"a\",\"a-0\",{\"href\":\"https://apps.apple.com/us/app/kultura/id1591618437\",\"target\":\"_blank\",\"children\":\"AppStore\"}]]}],\"\\n\",[\"$\",\"p\",\"p-2\",{\"children\":\"Skills: Swift, UIKit, SwiftUI, TCA, Combine, Swift Structured Concurrency, swift-dependancies, AVFoundation, CoreData.\"}]]}],null]}]]}]]}]]}],[\"$\",\"section\",\"Side Projects\",{\"className\":\"Profile_profileSection___hycX\",\"children\":[[\"$\",\"h3\",null,{\"children\":\"Side Projects\"}],[\"$\",\"div\",null,{\"className\":\"Profile_experiences__Z2lAW\",\"children\":[[\"$\",\"div\",\"Bluerage Software\",{\"className\":\"Profile_experience__8pQJc\",\"children\":[[\"$\",\"div\",null,{\"className\":\"Profile_year__KzJ4a\",\"children\":[\"$\",\"span\",null,{\"children\":\"2025 — Now\"}]}],[\"$\",\"div\",null,{\"className\":\"$undefined\",\"children\":[[\"$\",\"div\",null,{\"className\":\"Profile_title__DhufJ\",\"children\":[[\"$\",\"a\",null,{\"href\":\"https://bluerage.software\",\"target\":\"_blank\",\"children\":\"Bluerage Software\"}],[\"$\",\"span\",null,{\"className\":\"Profile_linkArrow__Kwzq5\",\"children\":[\"﻿\",[\"$\",\"svg\",null,{\"width\":\"12\",\"height\":\"12\",\"viewBox\":\"0 0 12 12\",\"fill\":\"none\",\"xmlns\":\"http://www.w3.org/2000/svg\",\"children\":[\"$\",\"path\",null,{\"d\":\"M3.5 3C3.22386 3 3 3.22386 3 3.5C3 3.77614 3.22386 4 3.5 4V3ZM8.5 3.5H9C9 3.22386 8.77614 3 8.5 3V3.5ZM8 8.5C8 8.77614 8.22386 9 8.5 9C8.77614 9 9 8.77614 9 8.5H8ZM2.64645 8.64645C2.45118 8.84171 2.45118 9.15829 2.64645 9.35355C2.84171 9.54882 3.15829 9.54882 3.35355 9.35355L2.64645 8.64645ZM3.5 4H8.5V3H3.5V4ZM8 3.5V8.5H9V3.5H8ZM8.14645 3.14645L2.64645 8.64645L3.35355 9.35355L8.85355 3.85355L8.14645 3.14645Z\",\"fill\":\"var(--grey1)\"}]}]]}]]}],null,[\"$\",\"div\",null,{\"className\":\"Profile_description__OMT9q\",\"children\":[[\"$\",\"p\",\"p-0\",{\"children\":\"We started as a platform for creating MiniApps using prompts from your phone end to end. Since software creation became cheap, users that were prior not able to express their ideas now could instantly create and share them\"}],\"\\n\",[\"$\",\"p\",\"p-1\",{\"children\":[\"We were in close connection with \",[\"$\",\"a\",\"a-0\",{\"href\":\"https://zfellows.com\",\"target\":\"_blank\",\"children\":\"zfellows\"}],\" while working on this idea\"]}],\"\\n\",[\"$\",\"p\",\"p-2\",{\"children\":\"We then decided to pivot from an iOS app to a Telegram bot and target an already existing Telegram MiniApps platform\"}],\"\\n\",[\"$\",\"p\",\"p-3\",{\"children\":[\"Publications: \",[\"$\",\"a\",\"a-0\",{\"href\":\"https://x.com/blueragehq\",\"target\":\"_blank\",\"children\":\"X\"}],\", \",[\"$\",\"a\",\"a-1\",{\"href\":\"https://bluerage.software\",\"target\":\"_blank\",\"children\":\"Site\"}]]}],\"\\n\",[\"$\",\"p\",\"p-4\",{\"children\":\"Skills: Swift, UIKit, SwiftUI, Factory, Rive, WebKit, Supabase, swift-openapi, Nuke, PinLayout, Observation, mlx-swift, Fly, Sentry, PostHog, Railway, Axiom, Cloudflare, Next JS, Vercel AI SDK, Hono\"}]]}],null]}]]}],[\"$\",\"div\",\"Haptics\",{\"className\":\"Profile_experience__8pQJc\",\"children\":[[\"$\",\"div\",null,{\"className\":\"Profile_year__KzJ4a\",\"children\":[\"$\",\"span\",null,{\"children\":2024}]}],[\"$\",\"div\",null,{\"className\":\"$undefined\",\"children\":[[\"$\",\"div\",null,{\"className\":\"Profile_title__DhufJ\",\"children\":[[\"$\",\"a\",null,{\"href\":\"https://apps.apple.com/us/app/haptics-send-love-to-friends/id6503260004\",\"target\":\"_blank\",\"children\":\"Haptics\"}],[\"$\",\"span\",null,{\"className\":\"Profile_linkArrow__Kwzq5\",\"children\":[\"﻿\",[\"$\",\"svg\",null,{\"width\":\"12\",\"height\":\"12\",\"viewBox\":\"0 0 12 12\",\"fill\":\"none\",\"xmlns\":\"http://www.w3.org/2000/svg\",\"children\":[\"$\",\"path\",null,{\"d\":\"M3.5 3C3.22386 3 3 3.22386 3 3.5C3 3.77614 3.22386 4 3.5 4V3ZM8.5 3.5H9C9 3.22386 8.77614 3 8.5 3V3.5ZM8 8.5C8 8.77614 8.22386 9 8.5 9C8.77614 9 9 8.77614 9 8.5H8ZM2.64645 8.64645C2.45118 8.84171 2.45118 9.15829 2.64645 9.35355C2.84171 9.54882 3.15829 9.54882 3.35355 9.35355L2.64645 8.64645ZM3.5 4H8.5V3H3.5V4ZM8 3.5V8.5H9V3.5H8ZM8.14645 3.14645L2.64645 8.64645L3.35355 9.35355L8.85355 3.85355L8.14645 3.14645Z\",\"fill\":\"var(--grey1)\"}]}]]}]]}],null,[\"$\",\"div\",null,{\"className\":\"Profile_description__OMT9q\",\"children\":[[\"$\",\"p\",\"p-0\",{\"children\":\"I developed and shipped Haptics, an iOS application that enables real-time communication between users through touch, drawings, and interactive feedback. The app was featured by the Spotted in Prod Twitter account and gained significant interest in design community\"}],\"\\n\",[\"$\",\"p\",\"p-1\",{\"children\":\"Technical: custom highly optimised CoreAnimation drawing engine, Metal based visual effects, SpriteKit scenes, single source of truth mvvm based architecture\"}],\"\\n\",[\"$\",\"p\",\"p-2\",{\"children\":[\"Publications: \",[\"$\",\"a\",\"a-0\",{\"href\":\"https://apps.apple.com/us/app/haptics-send-love-to-friends/id6503260004\",\"target\":\"_blank\",\"children\":\"AppStore\"}],\", \",[\"$\",\"a\",\"a-1\",{\"href\":\"https://x.com/spottedinprod/status/1847377048417030216\",\"target\":\"_blank\",\"children\":\"Spotted in Prod\"}]]}],\"\\n\",[\"$\",\"p\",\"p-3\",{\"children\":\"Skills: Swift, UIKit, SwiftUI, swift-dependancies, Nuke, Firebase, Metal, CoreAnimation, CoreGraphics, SpriteKit, PinLayout, Yoga, WidgetKit, AppIntents, StoreKit, Combine, Swift Structured Concurrency, GCD\"}]]}],null]}]]}],[\"$\",\"div\",\"Reality\",{\"className\":\"Profile_experience__8pQJc\",\"children\":[[\"$\",\"div\",null,{\"className\":\"Profile_year__KzJ4a\",\"children\":[\"$\",\"span\",null,{\"children\":\"2023 — 2024\"}]}],[\"$\",\"div\",null,{\"className\":\"$undefined\",\"children\":[[\"$\",\"div\",null,{\"className\":\"Profile_title__DhufJ\",\"children\":[[\"$\",\"a\",null,{\"href\":\"https://apps.apple.com/us/app/reality-build-your-world/id6474273304\",\"target\":\"_blank\",\"children\":\"Reality\"}],[\"$\",\"span\",null,{\"className\":\"Profile_linkArrow__Kwzq5\",\"children\":[\"﻿\",[\"$\",\"svg\",null,{\"width\":\"12\",\"height\":\"12\",\"viewBox\":\"0 0 12 12\",\"fill\":\"none\",\"xmlns\":\"http://www.w3.org/2000/svg\",\"children\":[\"$\",\"path\",null,{\"d\":\"M3.5 3C3.22386 3 3 3.22386 3 3.5C3 3.77614 3.22386 4 3.5 4V3ZM8.5 3.5H9C9 3.22386 8.77614 3 8.5 3V3.5ZM8 8.5C8 8.77614 8.22386 9 8.5 9C8.77614 9 9 8.77614 9 8.5H8ZM2.64645 8.64645C2.45118 8.84171 2.45118 9.15829 2.64645 9.35355C2.84171 9.54882 3.15829 9.54882 3.35355 9.35355L2.64645 8.64645ZM3.5 4H8.5V3H3.5V4ZM8 3.5V8.5H9V3.5H8ZM8.14645 3.14645L2.64645 8.64645L3.35355 9.35355L8.85355 3.85355L8.14645 3.14645Z\",\"fill\":\"var(--grey1)\"}]}]]}]]}],null,[\"$\",\"div\",null,{\"className\":\"Profile_description__OMT9q\",\"children\":[[\"$\",\"p\",\"p-0\",{\"children\":\"I developed and shipped Reality, an AR iOS application that enables users to place digital assets in real-world locations and discover content left by others. The app creates a persistent digital layer over the physical world through advanced geospatial AR technology\"}],\"\\n\",[\"$\",\"p\",\"p-1\",{\"children\":\"Technical: ARKit + Google ARCore Geospatial API integration, RealityKit entity management system, GeoHash-based spatial querying with Firebase Firestore, VPS (Visual Positioning System) for precise world anchoring\"}],\"\\n\",[\"$\",\"p\",\"p-2\",{\"children\":[\"Publications: \",[\"$\",\"a\",\"a-0\",{\"href\":\"https://apps.apple.com/us/app/reality-build-your-world/id6474273304\",\"target\":\"_blank\",\"children\":\"AppStore\"}]]}],\"\\n\",[\"$\",\"p\",\"p-3\",{\"children\":\"Skills: Swift, UIKit, swift-dependancies, Nuke, Firebase, ARKit, RealityKit, CoreAnimation, CoreGraphics, PinLayout, Yoga, Combine, Swift Structured Concurrency, GCD, CoreLocation, AVFoundation, ARCore, MapKit\"}]]}],null]}]]}]]}]]}],[\"$\",\"section\",\"Speaking\",{\"className\":\"Profile_profileSection___hycX\",\"children\":[[\"$\",\"h3\",null,{\"children\":\"Speaking\"}],[\"$\",\"div\",null,{\"className\":\"Profile_experiences__Z2lAW\",\"children\":[[\"$\",\"div\",\"CoreImage\",{\"className\":\"Profile_experience__8pQJc\",\"children\":[[\"$\",\"div\",null,{\"className\":\"Profile_year__KzJ4a\",\"children\":[\"$\",\"span\",null,{\"children\":2023}]}],[\"$\",\"div\",null,{\"className\":\"$undefined\",\"children\":[[\"$\",\"div\",null,{\"className\":\"Profile_title__DhufJ\",\"children\":[[\"$\",\"a\",null,{\"href\":\"https://www.youtube.com/watch?v=WytO_dmqr7s\",\"target\":\"_blank\",\"children\":\"CoreImage\"}],[\"$\",\"span\",null,{\"className\":\"Profile_linkArrow__Kwzq5\",\"children\":[\"﻿\",[\"$\",\"svg\",null,{\"width\":\"12\",\"height\":\"12\",\"viewBox\":\"0 0 12 12\",\"fill\":\"none\",\"xmlns\":\"http://www.w3.org/2000/svg\",\"children\":[\"$\",\"path\",null,{\"d\":\"M3.5 3C3.22386 3 3 3.22386 3 3.5C3 3.77614 3.22386 4 3.5 4V3ZM8.5 3.5H9C9 3.22386 8.77614 3 8.5 3V3.5ZM8 8.5C8 8.77614 8.22386 9 8.5 9C8.77614 9 9 8.77614 9 8.5H8ZM2.64645 8.64645C2.45118 8.84171 2.45118 9.15829 2.64645 9.35355C2.84171 9.54882 3.15829 9.54882 3.35355 9.35355L2.64645 8.64645ZM3.5 4H8.5V3H3.5V4ZM8 3.5V8.5H9V3.5H8ZM8.14645 3.14645L2.64645 8.64645L3.35355 9.35355L8.85355 3.85355L8.14645 3.14645Z\",\"fill\":\"var(--grey1)\"}]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"Profile_location__j4kBh\",\"children\":\"Saint-Petersburg\"}],[\"$\",\"div\",null,{\"className\":\"Profile_description__OMT9q\",\"children\":[[\"$\",\"p\",\"p-0\",{\"children\":\"How we went from custom Accelerate based image filters to Metal and CoreImage\"}],\"\\n\",[\"$\",\"p\",\"p-1\",{\"children\":[\"Publications: \",[\"$\",\"a\",\"a-0\",{\"href\":\