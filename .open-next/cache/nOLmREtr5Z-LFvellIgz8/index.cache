about__YfjU6\",\"children\":[[\"$\",\"h3\",null,{\"children\":\"About\"}],[\"$\",\"div\",null,{\"className\":\"Profile_description__OMT9q\",\"children\":[[\"$\",\"p\",\"p-0\",{\"children\":\"Hi my name is Ertem! I'm a software engineer, whose main focus is creating stunning apps for Apple platforms. I value great design, which drives user attention, yet covering the needs, creativity in every part of the product and of course having fun along the way! I do a lot of side projects in my free time with my friends, mostly in consumer + AI space.\"}]]}]]}],[[\"$\",\"section\",\"Work Experience\",{\"className\":\"Profile_profileSection___hycX\",\"children\":[[\"$\",\"h3\",null,{\"children\":\"Work Experience\"}],[\"$\",\"div\",null,{\"className\":\"Profile_experiences__Z2lAW\",\"children\":[[\"$\",\"div\",\"Senior iOS Engineer at Infrastructure Team at VK\",{\"className\":\"Profile_experience__8pQJc\",\"children\":[[\"$\",\"div\",null,{\"className\":\"Profile_year__KzJ4a\",\"children\":[\"$\",\"span\",null,{\"children\":\"2024 — Now\"}]}],[\"$\",\"div\",null,{\"className\":\"$undefined\",\"children\":[[\"$\",\"div\",null,{\"className\":\"Profile_title__DhufJ\",\"children\":[[\"$\",\"a\",null,{\"href\":\"http://vk.com\",\"target\":\"_blank\",\"children\":\"Senior iOS Engineer at Infrastructure Team at VK\"}],[\"$\",\"span\",null,{\"className\":\"Profile_linkArrow__Kwzq5\",\"children\":[\"﻿\",[\"$\",\"svg\",null,{\"width\":\"12\",\"height\":\"12\",\"viewBox\":\"0 0 12 12\",\"fill\":\"none\",\"xmlns\":\"http://www.w3.org/2000/svg\",\"children\":[\"$\",\"path\",null,{\"d\":\"M3.5 3C3.22386 3 3 3.22386 3 3.5C3 3.77614 3.22386 4 3.5 4V3ZM8.5 3.5H9C9 3.22386 8.77614 3 8.5 3V3.5ZM8 8.5C8 8.77614 8.22386 9 8.5 9C8.77614 9 9 8.77614 9 8.5H8ZM2.64645 8.64645C2.45118 8.84171 2.45118 9.15829 2.64645 9.35355C2.84171 9.54882 3.15829 9.54882 3.35355 9.35355L2.64645 8.64645ZM3.5 4H8.5V3H3.5V4ZM8 3.5V8.5H9V3.5H8ZM8.14645 3.14645L2.64645 8.64645L3.35355 9.35355L8.85355 3.85355L8.14645 3.146