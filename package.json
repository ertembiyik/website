{
  "name": "simple-cv-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/build-data.js",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "preview": "npm run prebuild && opennextjs-cloudflare build && wrangler dev",
    "deploy": "npm run prebuild && opennextjs-cloudflare build && wrangler deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.0",
    "@mdx-js/react": "^3.1.0",
    "@next/mdx": "^15.5.0",
    "@types/mdx": "^2.0.13",
    "agentation": "^1.3.0",
    "framer-motion": "^11.14.4",
    "gray-matter": "^4.0.3",
    "next": "15.0.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.1",
    "react-scrollbooster": "^0.1.2",
    "use-resize-observer": "^9.1.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.6.5",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "^5",
    "wrangler": "^4.32.0"
  },
  "overrides": {
    "use-resize-observer": {
      "react": "^19",
      "react-dom": "^19"
    }
  }
