---
import Layout from "../../layouts/Layout.astro";
import VisibleMarkdown from "../../components/VisibleMarkdown.astro";

interface ContentFrontmatter {
  title: string;
  [key: string]: unknown;
}

interface ContentPage {
  file: string;
  frontmatter: ContentFrontmatter;
  rawContent(): string;
}

function getAllContent() {
  return import.meta.glob<ContentPage>("../../content/**/*.md", {
    eager: true,
  });
}

const allContent = getAllContent();

export function getStaticPaths() {
  const allContent = import.meta.glob<ContentPage>("../../content/**/*.md", {
    eager: true,
  });
  const exclude = new Set(["site.md", "404.md"]);

  return Object.values(allContent)
    .filter((page) => !exclude.has(page.file.split("/").at(-1) ?? ""))
    .flatMap((page) => {
      const parts = page.file.split("/");
      const fileName = parts.at(-1);
      const category = parts.at(-2);

      if (!fileName || !category) {
        return [];
      }

      return [{ params: { category, slug: fileName.replace(".md", "") } }];
    });
}

const { category, slug } = Astro.params;

if (!category || !slug) {
  throw new Error("Missing content route params.");
}

const page = Object.values(allContent).find((entry) =>
  entry.file.endsWith(`${category}/${slug}.md`),
);

if (!page) {
  throw new Error(`Content page not found for ${category}/${slug}.md`);
}

const { title } = page.frontmatter;
const content = page.rawContent();
---

<Layout title={`${title} — Ertem Biyik`}>
  <main transition:animate="slide">
    <p><a href="/" onclick="history.back(); return false">← back</a></p>
    <VisibleMarkdown text={content} />
  </main>
</Layout>

<style>
  main {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 64px 24px;
  }

  @media (max-width: 480px) {
    main {
      padding: 32px 16px;
    }
  }
</style>
