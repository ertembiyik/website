---
import Layout from "../layouts/Layout.astro";
import VisibleMarkdown from "../components/VisibleMarkdown.astro";
import * as site from "../content/site.md";

const { title, description } = site.frontmatter;
const content = site.rawContent();
---

<Layout title={title} description={description}>
  <main transition:animate="slide">
    <VisibleMarkdown text={content} />
  </main>
</Layout>

<style>
  main {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 64px 24px;
  }

  @media (max-width: 480px) {
    main {
      padding: 32px 16px;
    }
  }
</style>
