{
    "$schema": "node_modules/wrangler/config-schema.json",
    "main": "./dist/_worker.js/index.js",
    "name": "ertembiyik-site",
    "compatibility_date": "2025-08-23",
    "compatibility_flags": [
        "nodejs_compat"
    ],
    "observability": {
        "enabled": true
    },
    "assets": {
        "binding": "ASSETS",
        "directory": "./dist",
        "not_found_handling": "404-page"
    }
}